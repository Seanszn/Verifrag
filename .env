# Deployment Mode: local, cloud, or hybrid
DEPLOYMENT_MODE=local

# LLM Configuration
LLM_PROVIDER=ollama                    # ollama, openai, anthropic, gemini, hybrid
LLM_MODEL=llama3.1:8b                  # Model name for the provider
OLLAMA_HOST=http://localhost:11434

# Cloud LLM API Keys (if using cloud providers)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Azure OpenAI (enterprise deployments)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Vector Store Configuration
VECTOR_STORE=faiss                     # faiss, chroma, pinecone
PINECONE_API_KEY=
PINECONE_INDEX=legalverifirag

# Hybrid Mode Configuration
HYBRID_PRIVILEGED_PROVIDER=ollama      # Use local for privileged docs
HYBRID_DEFAULT_PROVIDER=openai         # Use cloud for public queries

# Cost Control
LLM_BUDGET_LIMIT=10.00                 # Monthly budget in USD
ENABLE_COST_TRACKING=true

# CourtListener API (optional, for higher rate limits)
COURTLISTENER_API_KEY=59eb9930055f1f672f326a01b98fcf3a5a3cf7e1
