# Deployment Mode: local only
DEPLOYMENT_MODE=local

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b                  # Ollama model name
OLLAMA_HOST=http://localhost:11434
LLM_MAX_TOKENS=1024                    # Lower default to reduce long-running generations
LLM_REQUEST_TIMEOUT_SECONDS=150
OLLAMA_NUM_CTX=4096
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_LOCAL_FILES_ONLY=1
NLI_MODEL=typeform/distilbert-base-uncased-mnli
NLI_DEVICE=cpu
VERIFICATION_FALLBACK_TO_HEURISTIC=true
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
API_CONNECT_TIMEOUT_SECONDS=10
API_REQUEST_TIMEOUT_SECONDS=30
API_QUERY_TIMEOUT_SECONDS=180
APP_LOG_LEVEL=INFO
APP_SLOW_REQUEST_THRESHOLD_MS=2000
AUTH_TOKEN_TTL_HOURS=24
DATABASE_PATH=data/legalverifirag.db
ENABLE_VERIFICATION=true             # Local default; set false for faster generation-only smoke tests
VERIFICATION_VERIFIER_MODE=live     # live or heuristic

# Vector Store Configuration
CHROMA_PATH=data/index/chroma
CHROMA_COLLECTION=legal_chunks
CHROMA_DISTANCE=cosine
CHROMA_BATCH_SIZE=100

# CourtListener API v4 (register at courtlistener.com, enable 2FA, generate token)
COURTLISTENER_TOKEN="e02c7fbdf5910d6e415b4018a7416f44ca05e913"
